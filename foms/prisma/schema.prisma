datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  SHIPPER
  DRIVER
}

model User {
  id                 String                 @id @default(cuid())
  email              String                 @unique
  password           String
  role               Role
  createdAt          DateTime               @default(now())

  createdShipments   Shipment[]             @relation("CreatedShipments")
  assignedShipments  Shipment[]             @relation("AssignedDriverShipments")
  statusUpdates      ShipmentStatusUpdate[]
}

model Shipment {
  id                   Int                      @id @default(autoincrement())
  reference            String
  origin               String
  destination          String
  status               String                   @default("Created")
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  shipper              User?                    @relation("CreatedShipments", fields: [shipperId], references: [id])
  shipperId            String?

  driver               User?                    @relation("AssignedDriverShipments", fields: [driverId], references: [id])
  driverId             String?

  statusUpdates        ShipmentStatusUpdate[]
  deliveryConfirmation DeliveryConfirmation?
}

model ShipmentStatusUpdate {
  id          Int      @id @default(autoincrement())
  status      String
  note        String?
  createdAt   DateTime @default(now())

  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId  Int

  updatedBy   User?    @relation(fields: [updatedById], references: [id])
  updatedById String?
}

model DeliveryConfirmation {
  id          Int      @id @default(autoincrement())
  confirmedAt DateTime @default(now())
  note        String?

  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  shipmentId  Int      @unique
}